{
	"name": "sportal",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "prisma generate && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:reset": "prisma migrate reset --force && prisma db push && prisma generate && tsx prisma/seed.ts",
		"db:resetonly": "prisma migrate reset --force && prisma db push",
		"db:seed": "prisma migrate dev && prisma generate && tsx prisma/seed.ts",
		"db:migrate": "prisma migrate dev && prisma generate",
		"db:generate": "prisma generate",
		"db:studio": "prisma studio",
		"db:push": "prisma db push && prisma generate",
		"db:fresh": "prisma db push && prisma generate && tsx prisma/seed.ts",
		"seed:all": "tsx prisma/seed.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.70.0",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.3",
		"@types/node": "^24.13.3",
		"@types/nodemailer": "^8.0.1",
		"@types/pg": "^8.20.0",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"pg": "^8.22.0",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"prisma": "^7.8.0",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^4.3.3",
		"tsx": "^4.23.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.5"
	},
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	},
	"dependencies": {
		"@node-rs/argon2": "^2.0.2",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@vitejs/plugin-basic-ssl": "^2.3.0",
		"dotenv": "^17.4.2",
		"lucide-svelte": "^1.0.1",
		"nodemailer": "^8.0.11"
	}
}
